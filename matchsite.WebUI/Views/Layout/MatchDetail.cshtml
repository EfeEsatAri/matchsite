@model matchsite.WebUI.Dtos.MatchDto.ResultMatchDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
    @await Component.InvokeAsync("_LayoutHeadComponentPartial")
<body style="background: #0b0e14;">
    @await Component.InvokeAsync("_LayoutNavbarComponentPartial")

    <main>
        <div class="wrap" style="padding-top:48px; padding-bottom:56px">
            <div class="container" style="max-width: 850px;">

                @if (Model != null)
                {
                    <div class="scoreboard-panel p-4 p-md-5 mb-4 text-center position-relative overflow-hidden"
                         style="background: linear-gradient(145deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 24px; backdrop-filter: blur(15px);">

                        <div class="mb-4">
                            @if (Model.MatchStatus == "FT" || Model.IsFinished)
                            {
                                <span class="badge bg-success border border-success-subtle px-3 py-1.5 fw-bold" style="font-size: 11px; letter-spacing: 1px;">MAÇ SONUCU</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark border border-info-subtle px-3 py-1.5 fw-bold" style="font-size: 11px; letter-spacing: 1px;">BAŞLAMADI</span>
                            }
                        </div>

                        <div class="row align-items-center justify-content-center g-4">
                            <div class="col-4 text-center">
                                <div class="d-inline-flex align-items-center justify-content-center mb-3 p-3 logo-container"
                                     style="width: 90px; height: 90px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px;">
                                    <img src="@Model.HomeTeamLogo" alt="@Model.HomeTeamName" onerror="this.src='https://placehold.co/64x64?text=⚽';" style="max-width: 60px; max-height: 60px; object-fit: contain;" />
                                </div>
                                <h3 class="text-white fw-bold m-0 text-truncate" style="font-size: 18px;">
                                    @(string.IsNullOrEmpty(Model.HomeTeamName) ? "Ev Sahibi" : Model.HomeTeamName)
                                </h3>
                            </div>

                            <div class="col-4 text-center">
                                <div class="d-flex align-items-center justify-content-center gap-3">
                                    @if (Model.MatchStatus == "FT" || Model.IsFinished)
                                    {
                                        <span class="display-4 fw-black text-white">@Model.HomeScore</span>
                                        <span class="display-4 fw-light text-white-50">:</span>
                                        <span class="display-4 fw-black text-white">@Model.AwayScore</span>
                                    }
                                    else
                                    {
                                        <span class="display-4 fw-medium text-white-50" style="font-size: 2.2rem;">@Model.MatchDate.ToString("HH:mm")</span>
                                    }
                                </div>
                                <div class="text-white-50 mt-2 small">
                                    @if (Model.MatchDate.Year > 2000)
                                    {
                                        @Model.MatchDate.ToString("dd MMMM yyyy")
                                    }
                                    else
                                    {
                                        <span>Tarih Belirtilmedi</span>
                                    }
                                </div>
                            </div>

                            <div class="col-4 text-center">
                                <div class="d-inline-flex align-items-center justify-content-center mb-3 p-3 logo-container"
                                     style="width: 90px; height: 90px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px;">
                                    <img src="@Model.AwayTeamLogo" alt="@Model.AwayTeamName" onerror="this.src='https://placehold.co/64x64?text=⚽';" style="max-width: 60px; max-height: 60px; object-fit: contain;" />
                                </div>
                                <h3 class="text-white fw-bold m-0 text-truncate" style="font-size: 18px;">
                                    @(string.IsNullOrEmpty(Model.AwayTeamName) ? "Deplasman" : Model.AwayTeamName)
                                </h3>
                            </div>
                        </div>
                    </div>

                    <div class="details-panel p-4 mb-4"
                         style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px;">
                        <div class="sec-ttl mb-3 fw-bold text-uppercase tracking-wider text-white-50" style="font-size: 12px; letter-spacing: 0.5px;">
                            <i class="bi bi-info-circle me-1 text-info"></i> Maç Bilgileri
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-sm-6">
                                <div class="p-3 rounded-3 d-flex align-items-center gap-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04)">
                                    <i class="bi bi-building text-info" style="font-size: 20px;"></i>
                                    <div>
                                        <div class="text-white-50" style="font-size: 11px;">Stadyum</div>
                                        <div class="text-white fw-medium" style="font-size: 14px;">Premier League Standard</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-6">
                                <div class="p-3 rounded-3 d-flex align-items-center gap-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04)">
                                    <i class="bi bi-clock-history text-warning" style="font-size: 20px;"></i>
                                    <div>
                                        <div class="text-white-50" style="font-size: 11px;">Maç Periyodu</div>
                                        <div class="text-white fw-medium" style="font-size: 14px;">
                                            @(Model.MatchStatus == "FT" || Model.IsFinished ? "90' Tamamlandı" : "Başlamadı")
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-6">
                                <div class="p-3 rounded-3 d-flex align-items-center gap-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04)">
                                    <i class="bi bi-trophy text-danger" style="font-size: 20px;"></i>
                                    <div>
                                        <div class="text-white-50" style="font-size: 11px;">Lig / Turnuva</div>
                                        <div class="text-white fw-medium" style="font-size: 14px;">Premier League</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-6">
                                <div class="p-3 rounded-3 d-flex align-items-center gap-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04)">
                                    <i class="bi bi-hash text-success" style="font-size: 20px;"></i>
                                    <div>
                                        <div class="text-white-50" style="font-size: 11px;">Maç No</div>
                                        <div class="text-white fw-medium" style="font-size: 14px;">#00@(Model.MatchId)</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="details-panel p-4 mb-4" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px;">
                        <div class="sec-ttl mb-4 fw-bold text-uppercase tracking-wider text-white-50" style="font-size: 12px; letter-spacing: 0.5px;">
                            <i class="bi bi-lightning-charge me-1 text-success"></i> Maç Kronolojisi
                        </div>

                        <div class="timeline-container position-relative py-3">
                            <div class="timeline-line position-absolute start-50 translate-x-middle h-100" style="width: 2px; background: rgba(255,255,255,0.08); top: 0; transform: translateX(-50%);"></div>

                            @if (Model.MatchEvent != null && Model.MatchEvent.Any())
                            {
                                foreach (var ev in Model.MatchEvent)
                                {
                                    // Ev sahibi takım ismi eşleşmesine göre sola veya sağa yaslama kontrolü
                                    bool isHome = string.Equals(ev.TeamName, Model.HomeTeamName, StringComparison.OrdinalIgnoreCase);

                                    <div class="timeline-row d-flex w-100 mb-4 align-items-center position-relative @(isHome ? "flex-row" : "flex-row-reverse")">

                                        <div class="timeline-card-wrapper w-50 px-4 @(isHome ? "text-end" : "text-start")">
                                            <div class="d-inline-block p-3 event-card text-start" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 14px; min-width: 200px; max-width: 340px; backdrop-filter: blur(5px);">
                                                <div class="d-flex align-items-center gap-2 mb-1 @(isHome ? "justify-content-end" : "justify-content-start")">

                                                    @if (!isHome)
                                                    {
                                                        <span class="text-white fw-bold" style="font-size: 14px;">@ev.PlayerFullName</span>
                                                    }

                                                    @if (ev.EventTypeName == "Goal" || ev.EventTypeName == "Gol")
                                                    {
                                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-circle p-1 d-inline-flex justify-content-center align-items-center" style="width: 22px; height: 22px;"><i class="bi bi-soccer"></i></span>
                                                    }
                                                    else if (ev.EventTypeName == "YellowCard" || ev.EventTypeName == "Sarı Kart")
                                                    {
                                                        <div style="width: 11px; height: 15px; background: #ffc107; border-radius: 2px; box-shadow: 0 0 8px rgba(255,193,7,0.4);"></div>
                                                    }
                                                    else if (ev.EventTypeName == "RedCard" || ev.EventTypeName == "Kırmızı Kart")
                                                    {
                                                        <div style="width: 11px; height: 15px; background: #dc3545; border-radius: 2px; box-shadow: 0 0 8px rgba(220,53,69,0.4);"></div>
                                                    }
                                                    else if (ev.EventTypeName == "Substitution" || ev.EventTypeName == "Oyuncu Değişikliği")
                                                    {
                                                        <span class="text-info d-inline-flex"><i class="bi bi-arrow-left-right" style="font-size: 13px;"></i></span>
                                                    }

                                                    @if (isHome)
                                                    {
                                                        <span class="text-white fw-bold" style="font-size: 14px;">@ev.PlayerFullName</span>
                                                    }
                                                </div>

                                                <div class="text-white-50 @(isHome ? "text-end" : "text-start")" style="font-size: 11px; letter-spacing: 0.2px;">
                                                    @ev.Description
                                                    @if (!string.IsNullOrEmpty(ev.RelatedPlayerFullName))
                                                    {
                                                        <span class="text-info opacity-75">(@ev.RelatedPlayerFullName)</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <div class="timeline-badge position-absolute start-50 translate-middle-x d-flex align-items-center justify-content-center rounded-circle text-white fw-bold border"
                                             style="width: 38px; height: 38px; font-size: 12px; background: #0f131a; border-color: rgba(255,255,255,0.15) !important; z-index: 2; left: 50%; transform: translateX(-50%); box-shadow: 0 0 12px rgba(0,0,0,0.6);">
                                            <span>
                                                @ev.Minute'
                                                @if (ev.ExtraTime.HasValue && ev.ExtraTime.Value > 0)
                                                {
                                                    <small class="text-success" style="font-size: 9px; margin-left: -2px;">+@ev.ExtraTime</small>
                                                }
                                            </span>
                                        </div>

                                        <div class="w-50"></div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center text-white-50 py-4 small">
                                    <i class="bi bi-calendar-x d-block mb-2 opacity-50" style="font-size: 24px;"></i>
                                    Bu maça ait henüz bir kritik kronolojik olay kaydı bulunmuyor.
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row g-4 mb-4">

                        <div class="col-12 col-md-6">
                            <div class="p-4 h-100" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px;">
                                <div class="fw-bold text-uppercase text-white-50 mb-3" style="font-size: 11px; letter-spacing: 0.5px;"><i class="bi bi-soccer text-success me-1"></i> Gol Atanlar</div>
                                <div class="d-flex flex-column gap-2">
                                    @if (Model.MatchEvent != null)
                                    {
                                        var goller = Model.MatchEvent.Where(x => x.EventTypeName == "Goal" || x.EventTypeName == "Gol").ToList();
                                        if (goller.Any())
                                        {
                                            foreach (var gol in goller)
                                            {
                                                <div class="d-flex justify-content-between align-items-center p-2.5 rounded-3" style="background: rgba(255,255,255,0.015); border: 1px solid rgba(255,255,255,0.03)">
                                                    <span class="text-white small fw-medium">@gol.PlayerFullName <small class="text-white-50 ms-1" style="font-size:10px;">(@gol.TeamName)</small></span>
                                                    <span class="badge bg-dark border border-secondary-subtle text-white-50 font-monospace">@gol.Minute'</span>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-white-50 small opacity-50 p-2 italic" style="font-size:12px;">Bu maçta gol sesi çıkmadı.</span>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="p-4 h-100" style="background: rgba(255, 255, 255, 0.01); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px;">
                                <div class="fw-bold text-uppercase text-white-50 mb-3" style="font-size: 11px; letter-spacing: 0.5px;"><i class="bi bi-square-fill text-warning me-1"></i> Kart Görenler</div>
                                <div class="d-flex flex-column gap-2">
                                    @if (Model.MatchEvent != null)
                                    {
                                        var kartlar = Model.MatchEvent.Where(x => x.EventTypeName == "YellowCard" || x.EventTypeName == "RedCard" || x.EventTypeName == "Sarı Kart" || x.EventTypeName == "Kırmızı Kart").ToList();
                                        if (kartlar.Any())
                                        {
                                            foreach (var card in kartlar)
                                            {
                                                bool isYellow = card.EventTypeName.Contains("Yellow") || card.EventTypeName.Contains("Sarı");
                                                <div class="d-flex justify-content-between align-items-center p-2.5 rounded-3" style="background: rgba(255,255,255,0.015); border: 1px solid rgba(255,255,255,0.03)">
                                                    <span class="text-white small fw-medium d-flex align-items-center gap-2">
                                                        <span class="d-inline-block" style="width: 8px; height: 12px; background: @(isYellow ? "#ffc107" : "#dc3545"); border-radius: 2px;"></span>
                                                        @card.PlayerFullName <small class="text-white-50" style="font-size:10px;">密 (@card.TeamName)</small>
                                                    </span>
                                                    <span class="badge bg-dark border border-secondary-subtle text-white-50 font-monospace">@card.Minute'</span>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-white-50 small opacity-50 p-2 italic" style="font-size:12px;">Kart çıkmayan sakin bir maç.</span>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="text-center mt-4">
                        <a href="javascript:history.back()" class="btn btn-sm btn-outline-light px-4 py-2-5 backend-back-btn" style="border-radius: 10px; font-size: 12px; opacity: 0.6; transition: all 0.3s ease;">
                            <i class="bi bi-arrow-left me-1"></i> Geri Dön
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-center text-white p-5">Maç bilgisi yüklenemedi.</div>
                }

            </div>
        </div>
    </main>

    @await Component.InvokeAsync("_LayoutFooterComponentPartial")
</body>
</html>

<style>
    .fw-black {
        font-weight: 900;
    }

    .logo-container {
        transition: transform 0.3s ease;
    }

    .scoreboard-panel:hover .logo-container {
        transform: scale(1.04);
    }

    .event-card {
        transition: background 0.3s ease, border-color 0.3s ease;
    }

        .event-card:hover {
            background: rgba(255, 255, 255, 0.04) !important;
            border-color: rgba(255, 255, 255, 0.12) !important;
        }

    .backend-back-btn:hover {
        opacity: 1 !important;
        background-color: rgba(255,255,255,0.05);
    }
</style>