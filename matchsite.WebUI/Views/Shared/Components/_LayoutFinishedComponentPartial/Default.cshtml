<div class="sec-ttl mcw-section mb-3 fw-bold text-uppercase tracking-wider text-light d-flex align-items-center" data-s="finished" style="margin-top:28px; font-size: 14px; opacity: 0.9; letter-spacing: 0.5px;">
    <i class="bi bi-check-circle-fill text-success me-2"></i> Tamamlanan Maçlar
</div>

<div class="mc-wrap mcw d-flex flex-column gap-2" data-s="finished">
    @if (ViewBag.FinishedMatches != null && ((List<ResultMatchDto>)ViewBag.FinishedMatches).Count > 0)
    {
        // Controller'dan hazır filtrelenmiş gelen listeyi direkt döndürüyoruz
        foreach (var match in (List<ResultMatchDto>)ViewBag.FinishedMatches)
        {
            <a href="/Layout/MatchDetail/@match.MatchId" class="mc-custom-card d-flex align-items-center justify-content-between p-3 text-decoration-none transition-all"
               style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; backdrop-filter: blur(10px); transition: transform 0.2s, background 0.2s;">

                <div class="d-flex flex-column align-items-center justify-content-center pe-3 border-end" style="border-color: rgba(255,255,255,0.08) !important; min-width: 70px;">
                    <div class="fw-bold text-white" style="font-size: 14px;">@match.MatchDate.ToString("HH:mm")</div>
                    <div class="badge bg-success-subtle text-success border border-success-subtle mt-1 px-2 py-0.5" style="font-size: 10px; font-weight: 700;">MS</div>
                </div>

                <div class="flex-grow-1 px-4">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center justify-content-center p-1" style="width: 32px; height: 32px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;">
                                <img src="@match.HomeTeamLogo" alt="@match.HomeTeamName" onerror="this.src='https://placehold.co/24x24?text=⚽';" style="width:24px; height:24px; object-fit:contain;" />
                            </div>
                            <span class="text-white fw-medium" style="font-size: 14px;">@match.HomeTeamName</span>
                        </div>
                        <span class="fw-bold text-white" style="font-size: 16px;">@match.HomeScore</span>
                    </div>

                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center justify-content-center p-1" style="width: 32px; height: 32px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;">
                                <img src="@match.AwayTeamLogo" alt="@match.AwayTeamName" onerror="this.src='https://placehold.co/24x24?text=⚽';" style="width:24px; height:24px; object-fit:contain;" />
                            </div>
                            <span class="text-white fw-medium" style="font-size: 14px;">@match.AwayTeamName</span>
                        </div>
                        <span class="fw-bold text-white" style="font-size: 16px;">@match.AwayScore</span>
                    </div>
                </div>

                <div class="det-arrow ps-3 text-info transition-all" style="opacity: 0.6;">
                    <i class="bi bi-chevron-right" style="font-size: 18px;"></i>
                </div>
            </a>
        }
    }
    else
    {
        <div class="text-center p-4 text-white-50 rounded border" style="background: rgba(255,255,255,0.01); border-color: rgba(255,255,255,0.06) !important; font-size: 13px;">
            Yakın zamanda tamamlanmış maç bulunmuyor.
        </div>
    }
</div>

<style>
    .mc-custom-card:hover {
        background: rgba(255, 255, 255, 0.05) !important;
        border-color: rgba(255, 255, 255, 0.12) !important;
        transform: translateX(2px); /* Sağa doğru hafif tatlı bir kayma efekti */
    }

        .mc-custom-card:hover .det-arrow {
            opacity: 1 !important;
            color: #0dcaf0 !important;
        }
</style>