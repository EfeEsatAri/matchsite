@model List<ResultStandingDto>
@{
    ViewData["Title"] = "Puan Durumu";
    Layout = "~/Views/Admin/Index.cshtml";
    int count = 0;
}

<style>
    .matchmind-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
        color: #333;
    }

    .matchmind-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

        .matchmind-header h3 {
            margin: 0;
            font-size: 24px;
            color: #111;
        }

    .mm-btn-primary {
        background-color: #0f5132; /* Temandaki yeşil tonu */
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
    }

    .mm-table-wrapper {
        background: white;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        overflow: hidden;
        border: 1px solid #e0e0e0;
    }

    .mm-table {
        width: 100%;
        border-collapse: collapse;
        text-align: center; /* Sayısal veriler için ortalama daha iyi durur */
    }

        .mm-table th {
            background-color: #f8f9fa;
            color: #555;
            font-weight: 600;
            padding: 14px 12px;
            border-bottom: 2px solid #dee2e6;
            font-size: 13px;
        }

        .mm-table td {
            padding: 14px 12px;
            border-bottom: 1px solid #dee2e6;
            vertical-align: middle;
            font-size: 14px;
        }

        .mm-table tbody tr:hover {
            background-color: #fdfdfd;
        }
    /* İlk 4 takım yeşil (Şampiyonlar Ligi / Playoff vurgusu) */
    .zone-top {
        border-left: 4px solid #198754;
    }
    /* Son 3 takım kırmızı (Küme düşme vurgusu) */
    .zone-bottom {
        border-left: 4px solid #dc3545;
    }

    .mm-badge-form {
        display: inline-block;
        width: 20px;
        height: 20px;
        line-height: 20px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: bold;
        color: white;
        margin: 0 2px;
    }

    .form-w {
        background-color: #198754;
    }
    /* Win - Galibiyet */
    .form-d {
        background-color: #6c757d;
    }
    /* Draw - Beraberlik */
    .form-l {
        background-color: #dc3545;
    }
    /* Lost - Mağlubiyet */

    .mm-btn-action {
        padding: 6px 12px;
        border-radius: 4px;
        text-decoration: none;
        font-size: 13px;
        margin-right: 5px;
        display: inline-block;
    }

    .mm-btn-edit {
        background-color: #ffc107;
        color: #000;
    }

    .mm-btn-delete {
        background-color: #dc3545;
        color: #fff;
    }
</style>

<div class="matchmind-container">
    <div class="matchmind-header">
        <h3>Lig Puan Durumu</h3>
        <a href="/AdminStanding/CreateStanding" class="mm-btn-primary">Yeni Takım İstatistiği Ekle</a>
    </div>

    <div class="mm-table-wrapper">
        <table class="mm-table">
            <thead>
                <tr>
                    <th style="width: 5%">Sıra</th>
                    <th style="text-align: left; width: 25%">Takım Adı</th>
                    <th style="width: 6%">OM</th>
                    <th style="width: 6%">G</th>
                    <th style="width: 6%">B</th>
                    <th style="width: 6%">M</th>
                    <th style="width: 8%">AG</th>
                    <th style="width: 8%">YG</th>
                    <th style="width: 7%">AV</th>
                    <th style="width: 8%">Puan</th>
                    <th style="width: 15%">Son 5 Maç</th>
                    <th style="width: 15%">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        count++;
                        string zoneClass = "";
                        if (count <= 4) zoneClass = "zone-top";
                        else if (count > Model.Count - 3) zoneClass = "zone-bottom";

                        <tr class="@zoneClass">
                            <td><strong>@count</strong></td>
                            <td style="text-align: left; font-weight: 600;">@item.TeamName</td>
                            <td>@item.Played</td>
                            <td style="color: #198754; font-weight: 500;">@item.Won</td>
                            <td style="color: #6c757d; font-weight: 500;">@item.Draw</td>
                            <td style="color: #dc3545; font-weight: 500;">@item.Lost</td>
                            <td>@item.GoalsFor</td>
                            <td>@item.GoalsAgainst</td>
                            <td style="font-weight: 500; color: @(item.GoalDifference >= 0 ? "#198754" : "#dc3545")">
                                @(item.GoalDifference > 0 ? "+" + item.GoalDifference : item.GoalDifference.ToString())
                            </td>
                            <td style="font-weight: bold; font-size: 15px; color: #0f5132;">@item.Points</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.LastFiveMatches))
                                {
                                    // Örn: "W|D|L|W|W" yapısını parçalayıp küçük renkli kutucuklar yapıyoruz
                                    var forms = item.LastFiveMatches.Split('|');
                                    foreach (var f in forms)
                                    {
                                        if (f.Trim().ToUpper() == "W")
                                        {
                                            <span class="mm-badge-form form-w">G</span>
                                        }
                                        else if (f.Trim().ToUpper() == "D")
                                        {

                                            <span class="mm-badge-form form-d">B</span>
                                        }
                                        else if (f.Trim().ToUpper() == "L")
                                        {

                                            <span class="mm-badge-form form-l">M</span>
                                        }
                                    }
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>
                                <a href="/AdminStanding/UpdateStanding/@item.StandingId" class="mm-btn-action mm-btn-edit">Güncelle</a>
                                <a href="/AdminStanding/DeleteStanding/@item.StandingId" class="mm-btn-action mm-btn-delete" onclick="return confirm('Bu takımın puan durumu verisini silmek istediğine emin misin?')">Sil</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="12" style="text-align: center; color: #777; padding: 30px;">Puan durumu verisi bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

