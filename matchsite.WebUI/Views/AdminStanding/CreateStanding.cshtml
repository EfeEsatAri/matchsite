@model CreateStandingDto
@{
    ViewData["Title"] = "Yeni Puan Durumu Ekle";
    Layout = "~/Views/Admin/Index.cshtml";
}

<style>
    .matchmind-form-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
        color: #333;
        max-width: 700px; /* Tablo verileri çok olduğu için formu biraz genişlettik */
    }

    .matchmind-form-header {
        margin-bottom: 25px;
    }

        .matchmind-form-header h3 {
            margin: 0;
            font-size: 24px;
            color: #111;
        }

    .mm-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
        padding: 25px;
    }

    .mm-row {
        display: flex;
        gap: 15px;
        margin-bottom: 15px;
    }

    .mm-col {
        flex: 1;
    }

    .mm-form-group {
        margin-bottom: 15px;
    }

        .mm-form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 6px;
            color: #444;
            font-size: 13px;
        }

    .mm-form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: 14px;
        box-sizing: border-box;
        transition: border-color 0.2s;
    }

        .mm-form-control:focus {
            border-color: #0f5132;
            outline: none;
            box-shadow: 0 0 0 3px rgba(15, 81, 50, 0.1);
        }

    .mm-btn-group {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 25px;
    }

    .mm-btn {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        cursor: pointer;
        border: none;
    }

    .mm-btn-submit {
        background-color: #0f5132;
        color: white;
    }

        .mm-btn-submit:hover {
            background-color: #0b3d25;
        }

    .mm-btn-cancel {
        background-color: #e2e3e5;
        color: #333;
    }

        .mm-btn-cancel:hover {
            background-color: #d3d4d5;
        }
</style>

<div class="matchmind-form-container">
    <div class="matchmind-form-header">
        <h3>Takım İstatistiği Ekle</h3>
    </div>

    <div class="mm-card">
        <form  method="post">

            <div class="mm-form-group">
                <label for="TeamId">Takım</label>
                <select id="TeamId" name="TeamId" class="mm-form-control" required>
                    <option value="">İstatistik Eklenecek Takımı Seçiniz...</option>
                    @if (ViewBag.Teams != null)
                    {
                        foreach (var team in ViewBag.Teams)
                        {
                            var id = team.teamId ?? team.id;
                            var name = team.teamName ?? team.name;
                            <option value="@id">@name</option>
                        }
                    }
                </select>
            </div>

            <div class="mm-row">
                <div class="mm-col class=" mm-form-group"">
                    <label for="Played">Oynanan Maç (OM)</label>
                    <input type="number" id="Played" name="Played" class="mm-form-control" min="0" placeholder="0" required />
                </div>
                <div class="mm-col class=" mm-form-group"">
                    <label for="Won">Galibiyet (G)</label>
                    <input type="number" id="Won" name="Won" class="mm-form-control" min="0" placeholder="0" required />
                </div>
            </div>

            <div class="mm-row">
                <div class="mm-col class=" mm-form-group"">
                    <label for="Draw">Beraberlik (B)</label>
                    <input type="number" id="Draw" name="Draw" class="mm-form-control" min="0" placeholder="0" required />
                </div>
                <div class="mm-col class=" mm-form-group"">
                    <label for="Lost">Mağlubiyet (M)</label>
                    <input type="number" id="Lost" name="Lost" class="mm-form-control" min="0" placeholder="0" required />
                </div>
            </div>

            <div class="mm-row">
                <div class="mm-col class=" mm-form-group"">
                    <label for="GoalsFor">Atılan Gol (AG)</label>
                    <input type="number" id="GoalsFor" name="GoalsFor" class="mm-form-control" min="0" placeholder="0" required />
                </div>
                <div class="mm-col class=" mm-form-group"">
                    <label for="GoalsAgainst">Yenilen Gol (YG)</label>
                    <input type="number" id="GoalsAgainst" name="GoalsAgainst" class="mm-form-control" min="0" placeholder="0" required />
                </div>
            </div>

            <div class="mm-row">
                <div class="mm-col class=" mm-form-group"">
                    <label for="Points">Toplam Puan</label>
                    <input type="number" id="Points" name="Points" class="mm-form-control" min="0" placeholder="0" required />
                </div>
                <div class="mm-col class=" mm-form-group"">
                    <label for="LastFiveMatches">Son 5 Maç Formu (Örn: W|W|D|L|W)</label>
                    <input type="text" id="LastFiveMatches" name="LastFiveMatches" class="mm-form-control" placeholder="W|D|L|W|W" />
                    <small style="color: #6c757d; font-size: 11px; display:block; margin-top:4px;">
                        * Galibiyet için <strong>W</strong>, Beraberlik için <strong>D</strong>, Mağlubiyet için <strong>L</strong> yazıp aralarına dikey çizgi ( | ) koyun.
                    </small>
                </div>
            </div>

            <div class="mm-btn-group">
                <a href="/AdminStanding/Index" class="mm-btn mm-btn-cancel">İptal</a>
                <button type="submit" class="mm-btn mm-btn-submit">İstatistikleri Kaydet</button>
            </div>

        </form>
    </div>
</div>