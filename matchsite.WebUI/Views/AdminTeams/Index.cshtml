@model List<ResultTeamDto>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/Admin/Index.cshtml";
}

<style>
    /* Temanın CSS'ini ezen güçlü buton ve tablo stilleri */
    .custom-table tbody tr {
        transition: all 0.2s ease-in-out;
    }
    .custom-table tbody tr:hover {
        background-color: rgba(40, 167, 69, 0.04) !important; /* Sol menüdeki yeşile hafif bir vurgu */
        box-shadow: inset 4px 0 0 #28a745; /* Satırın soluna yeşil çizgi atar */
    }
    .admin-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        font-weight: 500;
        padding: 6px 14px !important;
        border-radius: 6px !important;
        transition: all 0.2s;
        text-decoration: none !important;
        font-size: 13px !important;
        border: 1px solid transparent;
    }
    .admin-btn-edit {
        background-color: #ffc107 !important;
        color: #000 !important;
    }
    .admin-btn-edit:hover {
        background-color: #e0a800 !important;
        transform: translateY(-1px);
        box-shadow: 0 4px 6px rgba(255, 193, 7, 0.2);
    }
    .admin-btn-delete {
        background-color: #dc3545 !important;
        color: #fff !important;
    }
    .admin-btn-delete:hover {
        background-color: #bd2130 !important;
        transform: translateY(-1px);
        box-shadow: 0 4px 6px rgba(220, 53, 69, 0.2);
    }
</style>

<div class="container-fluid pt-4">
    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 border-bottom">
            <h5 class="mb-0 text-dark fw-bold" style="font-size: 18px;">
                <i class="bi bi-shield-shaded text-success me-2"></i>Takım Yönetimi
            </h5>
            <a href="/AdminTeams/CreateTeam" class="btn btn-success px-4" style="border-radius: 8px; font-weight: 500;">
                <i class="small">+</i> Yeni Takım Ekle
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle custom-table mb-0">
                    <thead style="background-color: #f8f9fa;">
                        <tr class="text-dark border-bottom">
                            <th class="ps-4 py-3" style="width: 80px;">#</th>
                            <th style="width: 100px;">Logo</th>
                            <th>Takım Adı</th>
                            <th style="width: 150px;">Kısa Ad</th>
                            <th style="width: 250px;">Stadyum</th>
                            <th style="width: 220px;">Teknik Direktör</th>
                            <th class="text-center pe-4" style="width: 200px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr class="border-bottom">
                                    <td class="ps-4 fw-bold text-secondary">@item.TeamId</td>
                                    <td>
                                        <div class="d-flex align-items-center justify-content-start" style="width: 44px; height: 44px; background: #f1f3f5; border-radius: 8px; padding: 4px;">
                                            @if (!string.IsNullOrEmpty(item.LogoUrl))
                                            {
                                                <img src="@item.LogoUrl" style="width:100%; height:100%; object-fit:contain;" onerror="this.onerror=null; this.src='https://placehold.co/40x40?text=Logo';" />
                                            }
                                            else
                                            {
                                                <img src="https://placehold.co/40x40?text=Logo" style="width:100%; height:100%; object-fit:contain;" />
                                            }
                                        </div>
                                    </td>
                                    <td class="fw-bold text-dark" style="font-size: 15px;">@item.Name</td>
                                    <td>
                                        <span class="badge bg-light text-dark px-3 py-2 border" style="font-size: 13px; border-radius: 6px;">
                                            @item.ShortName
                                        </span>
                                    </td>
                                    <td class="text-secondary">@item.Stadium</td>
                                    <td class="text-secondary">@item.Coach</td>
                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="/AdminTeams/UpdateTeam/@item.TeamId" class="admin-btn admin-btn-edit">
                                                Düzenle
                                            </a>
                                            <a href="/AdminTeams/DeleteTeam/@item.TeamId" class="admin-btn admin-btn-delete" onclick="return confirm('@item.Name takımını silmek istediğinize emin misiniz?')">
                                                Sil
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <span class="d-block mb-2" style="font-size: 24px;">📂</span>
                                    Henüz hiç takım eklenmemiş.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
