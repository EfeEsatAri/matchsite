@model UpdateTeamDto
@{
    ViewData["Title"] = "Takım Güncelle";
    Layout = "~/Views/Admin/Index.cshtml";
}

<style>
    /* Temanın stilini koruyan ve çakışmayı önleyen özel form stilleri */
    .custom-form-group {
        margin-bottom: 20px;
    }

    .custom-label {
        display: block;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .custom-input {
        width: 100%;
        padding: 10px 14px;
        font-size: 14px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background-color: #fff;
        color: #333;
        transition: all 0.2s ease;
    }

        .custom-input:focus {
            border-color: #28a745 !important;
            outline: none;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.15);
        }

    .form-btn-container {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #f1f3f5;
    }

    /* Önizleme Alanı Stilleri */
    .preview-box {
        width: 100%;
        height: 110px;
        background-color: #f8f9fa;
        border: 2px dashed #e0e0e0;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 10px;
        overflow: hidden;
    }

    #logoPreview {
        max-width: 95px;
        max-height: 95px;
        object-fit: contain;
    }

    #logoPreviewText {
        color: #a0a0a0;
        font-size: 13px;
        display: none; /* Güncellemede zaten logo geleceği için başlangıçta gizli */
    }
</style>

<div class="container-fluid pt-4">
    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden; background: #fff;">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-dark fw-bold" style="font-size: 18px;">Takım Bilgilerini Güncelle</h5>
            <span class="badge bg-dark px-3 py-2" style="font-size: 12px; border-radius: 6px;">Takım ID: #@Model.TeamId</span>
        </div>

        <div class="card-body p-4">
            <form method="post">
                <input type="hidden" asp-for="TeamId" />

                <div class="custom-form-group">
                    <label class="custom-label">Takım Adı</label>
                    <input type="text" asp-for="Name" class="custom-input" required />
                </div>

                <div class="custom-form-group">
                    <label class="custom-label">Kısa Adı (Kısaltma)</label>
                    <input type="text" asp-for="ShortName" class="custom-input" required />
                </div>

                <div class="custom-form-group">
                    <label class="custom-label">Stadyum</label>
                    <input type="text" asp-for="Stadium" class="custom-input" required />
                </div>

                <div class="custom-form-group">
                    <label class="custom-label">Teknik Direktör</label>
                    <input type="text" asp-for="Coach" class="custom-input" required />
                </div>

                <div class="custom-form-group mb-0">
                    <label class="custom-label">Logo URL</label>
                    <input type="url" asp-for="LogoUrl" class="custom-input" id="logoInput" required />
                </div>

                <div class="custom-form-group">
                    <div class="preview-box">
                        <img src="@Model.LogoUrl" id="logoPreview" alt="Logo Önizleme" />
                        <span id="logoPreviewText">Logo Önizlemesi</span>
                    </div>
                </div>

                <div class="form-btn-container">
                    <a href="/AdminTeams/Index" class="btn btn-light px-4" style="border-radius: 8px; font-weight: 500; border: 1px solid #e0e0e0;">İptal</a>
                    <button type="submit" class="btn btn-warning px-4 text-dark" style="border-radius: 8px; font-weight: 600;">
                        Değişiklikleri Kaydet
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const logoInput = document.getElementById('logoInput');
        const logoPreview = document.getElementById('logoPreview');
        const logoPreviewText = document.getElementById('logoPreviewText');

        // Sayfa ilk açıldığında mevcut logonun kırık olup olmadığını kontrol et
        if(logoPreview.src) {
            checkImage(logoPreview);
        }

        // Kullanıcı URL'i değiştirdikçe çalışacak tetikleyiciler
        logoInput.addEventListener('input', function () {
            updatePreview(this.value);
        });

        logoInput.addEventListener('blur', function () {
            updatePreview(this.value);
        });

        function updatePreview(url) {
            if (url && url.trim() !== "") {
                logoPreview.src = url;
                logoPreview.style.display = 'block';
                logoPreviewText.style.display = 'none';
                checkImage(logoPreview);
            } else {
                logoPreview.style.display = 'none';
                logoPreviewText.style.display = 'block';
            }
        }

        function checkImage(imgElement) {
            imgElement.onerror = function() {
                this.src = 'https://placehold.co/95x95?text=Kırık+URL';
                this.style.opacity = '0.5';
            };
            imgElement.onload = function() {
                this.style.opacity = '1';
            };
        }
    });
</script>

