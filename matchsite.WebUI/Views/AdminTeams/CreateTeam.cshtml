@model CreateTeamDto
@{
    ViewData["Title"] = "Yeni Takım Ekle";
    Layout = "~/Views/Admin/Index.cshtml";
}

<style>
    /* Temanın stilini koruyan ve çakışmayı önleyen özel form stilleri */
    .custom-form-group {
        margin-bottom: 20px;
    }
    .custom-label {
        display: block;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        font-size: 14px;
    }
    .custom-input {
        width: 100%;
        padding: 10px 14px;
        font-size: 14px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background-color: #fff;
        color: #333;
        transition: all 0.2s ease;
    }
    .custom-input:focus {
        border-color: #28a745 !important;
        outline: none;
        box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.15);
    }
    .form-btn-container {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #f1f3f5;
    }

    /* Önizleme Alanı Stilleri */
    #logoPreviewContainer {
        width: 100%;
        height: 100px;
        background-color: #f8f9fa;
        border: 2px dashed #e0e0e0;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 10px;
        overflow: hidden;
    }
    #logoPreview {
        max-width: 90px;
        max-height: 90px;
        object-fit: contain;
        display: none; /* Başlangıçta gizli */
    }
    #logoPreviewText {
        color: #a0a0a0;
        font-size: 13px;
    }
</style>

<div class="container-fluid pt-4">
    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden; background: #fff;">
        <div class="card-header bg-white py-3 border-bottom">
            <h5 class="mb-0 text-dark fw-bold" style="font-size: 18px;">Yeni Takım Kaydı</h5>
        </div>

        <div class="card-body p-4">
            <form method="post">
                
                <div class="custom-form-group">
                    <label class="custom-label">Takım Adı</label>
                    <input type="text" asp-for="Name" class="custom-input" placeholder="Örn: Galatasaray" required />
                </div>

                <div class="custom-form-group">
                    <label class="custom-label">Kısa Adı (Kısaltma)</label>
                    <input type="text" asp-for="ShortName" class="custom-input" placeholder="Örn: GS" required />
                </div>

                <div class="custom-form-group">
                    <label class="custom-label">Stadyum</label>
                    <input type="text" asp-for="Stadium" class="custom-input" placeholder="Örn: Ali Sami Yen Spor Kompleksi" required />
                </div>

                <div class="custom-form-group">
                    <label class="custom-label">Teknik Direktör</label>
                    <input type="text" asp-for="Coach" class="custom-input" placeholder="Örn: Okan Buruk" required />
                </div>

                <div class="custom-form-group mb-0">
                    <label class="custom-label">Logo URL</label>
                    <input type="url" asp-for="LogoUrl" class="custom-input" id="logoInput" placeholder="https://ornek.com/logo.png" required />
                </div>

                <div class="custom-form-group">
                    <div id="logoPreviewContainer">
                        <img src="" id="logoPreview" alt="Logo Önizleme" />
                        <span id="logoPreviewText">Logo Önizlemesi</span>
                    </div>
                </div>
                <div class="form-btn-container">
                    <a href="/AdminTeams/Index" class="btn btn-light px-4" style="border-radius: 8px; font-weight: 500; border: 1px solid #e0e0e0;">İptal</a>
                    <button type="submit" class="btn btn-success px-4" style="border-radius: 8px; font-weight: 500;">
                        Takımı Kaydet
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const logoInput = document.getElementById('logoInput');
            const logoPreview = document.getElementById('logoPreview');
            const logoPreviewText = document.getElementById('logoPreviewText');

            // Kullanıcı URL kutusuna bir şey yapıştırdığında veya yazdığında çalışır
            logoInput.addEventListener('input', function () {
                updatePreview(this.value);
            });

            // Kullanıcı URL kutusundan çıktığında çalışır
            logoInput.addEventListener('blur', function () {
                updatePreview(this.value);
            });

            function updatePreview(url) {
                // Eğer URL boş değilse önizlemeyi dene
                if (url && url.trim() !== "") {
                    logoPreview.src = url;
                    logoPreview.style.display = 'block'; // Resimi göster
                    logoPreviewText.style.display = 'none'; // Yazıyı gizle

                    // Eğer URL hatalıysa (resim yüklenemezse) gri logoyu göster
                    logoPreview.onerror = function() {
                        this.src = 'https://placehold.co/90x90?text=Kırık+URL';
                        this.style.opacity = '0.5';
                    };
                    // Resim başarıyla yüklenirse opaklığı normale döndür
                    logoPreview.onload = function() {
                        this.style.opacity = '1';
                    };

                } else {
                    // URL boşsa varsayılan duruma dön
                    logoPreview.style.display = 'none';
                    logoPreviewText.style.display = 'block';
                }
            }
        });
    </script>
}

