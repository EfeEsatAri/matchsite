@model List<ResultMatchEventTypeDto>
@{
    ViewData["Title"] = "Maç Etkinlik Türleri";
    Layout = "~/Views/Admin/Index.cshtml";
    int count = 0;
}

<style>
    .matchmind-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
        color: #333;
    }

    .matchmind-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

        .matchmind-header h3 {
            margin: 0;
            font-size: 24px;
            color: #111;
        }

    .mm-btn-primary {
        background-color: #0f5132;
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
    }

    .mm-table-wrapper {
        background: white;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        overflow: hidden;
        border: 1px solid #e0e0e0;
    }

    .mm-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .mm-table th {
            background-color: #f8f9fa;
            color: #555;
            font-weight: 600;
            padding: 14px 12px;
            border-bottom: 2px solid #dee2e6;
            font-size: 13px;
        }

        .mm-table td {
            padding: 14px 12px;
            border-bottom: 1px solid #dee2e6;
            vertical-align: middle;
            font-size: 14px;
        }

        .mm-table tbody tr:hover {
            background-color: #fdfdfd;
        }

    .mm-color-preview {
        display: inline-block;
        width: 24px;
        height: 24px;
        border-radius: 4px;
        border: 1px solid #ccc;
        vertical-align: middle;
        margin-right: 8px;
    }

    .mm-btn-action {
        padding: 6px 12px;
        border-radius: 4px;
        text-decoration: none;
        font-size: 13px;
        margin-right: 5px;
        display: inline-block;
    }

    .mm-btn-edit {
        background-color: #ffc107;
        color: #000;
    }

    .mm-btn-delete {
        background-color: #dc3545;
        color: #fff;
    }
</style>

<div class="matchmind-container">
    <div class="matchmind-header">
        <h3>Maç Etkinlik Türleri</h3>
        <a href="/AdminMatchEventType/CreateMatchEventType" class="mm-btn-primary">Yeni Etkinlik Türü Ekle</a>
    </div>

    <div class="mm-table-wrapper">
        <table class="mm-table">
            <thead>
                <tr>
                    <th style="width: 8%">#</th>
                    <th style="width: 30%">Etkinlik Adı</th>
                    <th style="width: 20%">Renk</th>
                    <th style="width: 22%">İkon URL / Sınıfı</th>
                    <th style="width: 20%">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td><strong>@count</strong></td>
                            <td style="font-weight: 600;">@item.Name</td>
                            <td>
                                <span class="mm-color-preview" style="background-color: @item.Color;"></span>
                                <code>@item.Color</code>
                            </td>
                            <td>
                                <img src="@item.IconUrl" alt="icon" style="width: 32px; height: 32px; object-fit: contain; border-radius: 4px;" />
                            </td>
                            <td>
                                <a href="/AdminMatchEventType/UpdateMatchEventType/@item.MatchEventTypeId" class="mm-btn-action mm-btn-edit">Güncelle</a>
                                <a href="/AdminMatchEventType/DeleteMatchEventType/@item.MatchEventTypeId" class="mm-btn-action mm-btn-delete" onclick="return confirm('@item.Name etkinliğini silmek istediğine emin misin?')">Sil</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="text-align: center; color: #777; padding: 30px;">Henüz bir etkinlik türü (Gol, Kart vb.) eklenmemiş.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>