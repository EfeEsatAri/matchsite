@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Admin/Index.cshtml"; 
}

<style>
    .db-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
        color: #333;
    }

    .db-header {
        margin-bottom: 25px;
    }

        .db-header h2 {
            margin: 0;
            font-size: 26px;
            color: #111;
            font-weight: 700;
        }

        .db-header p {
            margin: 5px 0 0 0;
            color: #666;
            font-size: 14px;
        }

    /* İstatistik Kartları */
    .db-grid-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .db-card {
        background: white;
        border-radius: 10px;
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 1px solid #e6e6e6;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .db-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.05);
        }

    .db-card-info h3 {
        margin: 0;
        font-size: 28px;
        color: #111;
        font-weight: 700;
    }

    .db-card-info p {
        margin: 4px 0 0 0;
        color: #777;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .db-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Kart Renk Paletleri */
    .bg-teams {
        background-color: #e8f5e9;
        color: #2e7d32;
    }

    .bg-players {
        background-color: #e3f2fd;
        color: #1565c0;
    }

    .bg-matches {
        background-color: #fff3e0;
        color: #ef6c00;
    }

    .bg-events {
        background-color: #f3e5f5;
        color: #2b0b3d;
    }

    /* Alt Panel Düzeni */
    .db-sections {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
    }

    .db-panel {
        background: white;
        border-radius: 10px;
        border: 1px solid #e6e6e6;
        padding: 20px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

        .db-panel h4 {
            margin: 0 0 15px 0;
            font-size: 16px;
            color: #222;
            font-weight: 700;
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
        }

    /* Son Canlı Olaylar Listesi Simülasyonu */
    .activity-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .activity-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px;
        border-radius: 6px;
        background: #f9f9f9;
        font-size: 13px;
    }

    .activity-time {
        font-weight: bold;
        color: #0f5132;
        background: #e8f5e9;
        padding: 2px 6px;
        border-radius: 4px;
    }

    /* Hızlı Linkler */
    .quick-links {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .quick-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px;
        background: #f8f9fa;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        text-decoration: none;
        color: #4a5568;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.2s;
    }

        .quick-btn:hover {
            background: #0f5132;
            color: white;
            border-color: #0f5132;
        }

        .quick-btn svg {
            width: 16px;
            height: 16px;
        }
</style>

<div class="db-container">
    <div class="db-header">
        <h2>Dashboard</h2>
        <p>MatchMind yönetim paneline hoş geldiniz. Projenizin anlık veri özeti aşağıdadır.</p>
    </div>

    <div class="db-grid-cards">
        <div class="db-card">
            <div class="db-card-info">
                <h3>@ViewBag.TeamCount</h3>
                <p>Toplam Takım</p>
            </div>
            <div class="db-card-icon bg-teams">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
            </div>
        </div>

        <div class="db-card">
            <div class="db-card-info">
                <h3>@ViewBag.PlayerCount</h3>
                <p>Kayıtlı Oyuncu</p>
            </div>
            <div class="db-card-icon bg-players">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
            </div>
        </div>

        <div class="db-card">
            <div class="db-card-info">
                <h3>@ViewBag.MatchCount</h3>
                <p>Planlanan Maç</p>
            </div>
            <div class="db-card-icon bg-matches">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            </div>
        </div>

        <div class="db-card">
            <div class="db-card-info">
                <h3>@ViewBag.EventCount</h3>
                <p>Canlı Olay Girişi</p>
            </div>
            <div class="db-card-icon bg-events">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
            </div>
        </div>
    </div>

    <div class="db-sections">
        <div class="db-panel">
            <h4>Sistem Canlı Etkinlik Akışı</h4>
            <div class="activity-list">

                @if (ViewBag.LatestEvents != null && ((List<ResultMatchEventDto>)ViewBag.LatestEvents).Count > 0)
                {
                    foreach (var evnt in (List<ResultMatchEventDto>)ViewBag.LatestEvents)
                    {
                        <div class="activity-item">
                            <span class="activity-time">
                                @evnt.Minute'@(evnt.ExtraTime.HasValue && evnt.ExtraTime > 0 ? "+" + evnt.ExtraTime : "")
                            </span>

                            <span>
                                <strong>@evnt.TeamName</strong> takımında
                                @if (evnt.PlayerFullName != "N/A" && !string.IsNullOrEmpty(evnt.PlayerFullName))
                                {
                                    <strong>@evnt.PlayerFullName</strong>
                                }

                                @if (!string.IsNullOrEmpty(evnt.Description))
                                {
                                    <span>@evnt.Description</span>
                                }
                                else
                                {
                                    <span>bir hamle gerçekleştirdi.</span>
                                }

                                <small style="color: #888; font-weight: 500; margin-left: 5px;">(@evnt.EventTypeName)</small>
                            </span>
                        </div>
                    }
                }
                else
                {
                    <div class="activity-item" style="color: #777; font-style: italic; justify-content: center; padding: 20px;">
                        Henüz veritabanında kayıtlı canlı maç etkinliği bulunmuyor.
                    </div>
                }

                <div class="activity-item" style="background: #fffdf0; border: 1px dashed #ffeeba; margin-top: 5px;">
                    <span class="activity-time" style="background:#fff3e0; color:#ef6c00;">Sistem</span>
                    <span style="color:#666; font-weight: 500;">
                        API senkronizasyonu aktif. Toplam <strong>@ViewBag.EventCount</strong> canlı olay veritabanından anlık taranıyor.
                    </span>
                </div>
            </div>
        </div>

        <div class="db-panel">
            <h4>Hızlı Yönetim</h4>
            <div class="quick-links">
                <a href="/AdminMatches/Index" class="quick-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 8v8M8 12h8" /></svg>
                    Yeni Maç Planla
                </a>
                <a href="/AdminMatchEvent/CreateMatchEvent" class="quick-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11" /></svg>
                    Canlı Olay Kaydet
                </a>
                <a href="/AdminTeams/Index" class="quick-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                    Takımları Düzenle
                </a>
            </div>
        </div>
    </div>
</div>